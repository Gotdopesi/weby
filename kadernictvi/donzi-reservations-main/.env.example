# === Klient (Vite) — na Vercelu: Production + Preview ===
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_key
# ID barbershopu Donzi — po spuštění supabase/donzi_dobruska_setup.sql (typicky 2)
VITE_BARBERSHOP_ID=2
VITE_ANALYTICS_SITE_NAME=Barbershop Donzi

# Volitelné
# VITE_SUPABASE_REZERVACE_TABLE=kadernictvi_rezervace
# VITE_ADMIN_READ_ONLY_EMAILS=admin@demo.cz
# VITE_SITE_URL jen pro frontend — do e-mailů se nepoužívá

# === Server (Vercel Environment Variables — NIKDY s prefixem VITE_) ===
# Produkční doména pro odkazy „Zrušit rezervaci“ (NE *.vercel.app)
SITE_URL=https://donzi.dweby.cz
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=Rezervace <onboarding@resend.dev>
BULKGATE_APP_ID=00000
BULKGATE_APP_TOKEN=your_bulkgate_token
CRON_SECRET=change-me-to-random-string
