# === Klient (Vite) — na Vercelu: Production + Preview ===
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_key
VITE_BARBERSHOP_ID=1

# Volitelné
# VITE_SUPABASE_REZERVACE_TABLE=rezervace
# VITE_ADMIN_READ_ONLY_EMAILS=admin@demo.cz

# === Server (Vercel Environment Variables — NIKDY s prefixem VITE_) ===
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=Rezervace <onboarding@resend.dev>
BULKGATE_APP_ID=00000
BULKGATE_APP_TOKEN=your_bulkgate_token
# Vercel Cron posílá Authorization: Bearer <CRON_SECRET> automaticky; lokálně si nastavte:
CRON_SECRET=change-me-to-random-string
