# === Klient (Vite) — na Vercelu: Production + Preview ===
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_key
VITE_KADERNICTVI_ID=1
# Název v Vercel Analytics (události: „Studio Elegance — reserve_click“)
VITE_ANALYTICS_SITE_NAME=Studio Elegance
# Test registrace majitele (sandbox bez adminů — viz supabase/kadernictvi_admin_bootstrap.sql):
# VITE_KADERNICTVI_ID=<id ze SELECT id FROM kadernictvi WHERE slug = 'sandbox-registrace'>
# zpětná kompatibilita:
# VITE_BARBERSHOP_ID=1

# Volitelné — výchozí tabulky už jsou kadernictvi_*
# VITE_SUPABASE_REZERVACE_TABLE=kadernictvi_rezervace

# === DOČASNĚ jen lokálně (npm run dev) ===
# VITE_DEV_OWNER_EMAIL=dev.majitel@studio-elegance.test
# SUPABASE_SERVICE_ROLE_KEY=...   # pro node scripts/seed-dev-admins.mjs

# === Server (Vercel — bez prefixu VITE_) ===
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret
RESEND_API_KEY=re_xxxxxxxx
CRON_SECRET=change-me
BULKGATE_APP_ID=00000
BULKGATE_APP_TOKEN=your_bulkgate_token
