# Zkopírujte tento soubor jako `.env` v kořeni repozitáře a doplňte hodnoty z Supabase → Project Settings → API.

# Jen základ projektu (bez /rest/v1 na konci — i když omylem přidáte /rest/v1, build to opraví).
VITE_SUPABASE_URL=https://VÁŠ_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=VÁŠ_ANON_PUBLIC_KEY

# Volitelné — výchozí je `portfolio_poptavky`
# VITE_SUPABASE_PORTFOLIO_TABLE=portfolio_poptavky

# --- SQL pro krátký formulář na React webu (portfolio) ---
# create table public.portfolio_poptavky (
#   id uuid primary key default gen_random_uuid(),
#   created_at timestamptz not null default now(),
#   name text not null,
#   phone text not null,
#   typ_projektu text not null,
#   message text not null
# );
# alter table public.portfolio_poptavky enable row level security;
# create policy "anon insert portfolio" on public.portfolio_poptavky
#   for insert to anon with check (true);

# Dlouhý formulář ve složce dweby/ ukládá do tabulky `poptavky` — viz komentář v souboru dweby/poptavka.js

# --- Vercel (důležité) ---
# 1) Vercel nikdy „nevidí“ váš lokální soubor .env z počítače — musíte stejné proměnné zadat v
#    Project → Settings → Environment Variables (názvy přesně: VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY).
# 2) Prefix VITE_ je povinný, jinak je Vite v buildu nepropíše do prohlížeče.
# 3) Po přidání nebo změně proměnných spusťte znovu Deploy (Redeploy), aby se projekt znovu zbuildil.
# 4) Analytics: v projektu je @vercel/analytics — v dashboardu zapněte Web Analytics u tohoto projektu.
VITE_ANALYTICS_SITE_NAME=DWeby
